<!-- Views/DashboardPage.xaml -->
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FinanceiroPessoal.MAUI.Views.DashboardPage"
             Title="Dashboard">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="&#8249;" Command="{Binding MesAnteriorCommand}"/>
        <ToolbarItem Text="&#8250;" Command="{Binding ProximoMesCommand}"/>
    </ContentPage.ToolbarItems>

    <RefreshView IsRefreshing="{Binding Carregando}"
                 Command="{Binding CarregarCommand}">
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="12">

                <Label Text="{Binding ReferenciaFormatada}"
                       FontSize="18" FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <!-- Cards -->
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">

                    <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="#1D9E75"
                           CornerRadius="12" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="Entradas" TextColor="White" FontSize="12"/>
                            <Label Text="{Binding Resumo.TotalEntradas, StringFormat='R$ {0:N2}'}"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Resumo.QuantidadeEntradas, StringFormat='{0} lanÃ§amentos'}"
                                   TextColor="#9FE1CB" FontSize="11"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="#DC2626"
                           CornerRadius="12" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="SaÃ­das" TextColor="White" FontSize="12"/>
                            <Label Text="{Binding Resumo.TotalSaidas, StringFormat='R$ {0:N2}'}"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Resumo.QuantidadeSaidas, StringFormat='{0} lanÃ§amentos'}"
                                   TextColor="#F7C1C1" FontSize="11"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="#185FA5"
                           CornerRadius="12" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="Saldo" TextColor="White" FontSize="12"/>
                            <Label Text="{Binding Resumo.SaldoMes, StringFormat='R$ {0:N2}'}"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Resumo.TotalLancamentosMes, StringFormat='{0} lanÃ§amentos'}"
                                   TextColor="#B5D4F4" FontSize="11"/>
                        </VerticalStackLayout>
                    </Frame>

                    <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="#EF9F27"
                           CornerRadius="12" Padding="14" HasShadow="False">
                        <VerticalStackLayout>
                            <Label Text="PrÃ³x. 7 dias" TextColor="White" FontSize="12"/>
                            <Label Text="{Binding Resumo.TotalSemana, StringFormat='R$ {0:N2}'}"
                                   TextColor="White" FontSize="18" FontAttributes="Bold"/>
                            <Label Text="{Binding Resumo.QuantidadeSemana, StringFormat='{0} vencimentos'}"
                                   TextColor="#FAEEDA" FontSize="11"/>
                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <!-- Resumo -->
                <Frame BackgroundColor="White" CornerRadius="12" Padding="16" HasShadow="False"
                       BorderColor="#E5E7EB">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Resumo do mÃªs" FontSize="14" FontAttributes="Bold"/>
                        <Label Text="{Binding Resumo.TotalPago, StringFormat='SaÃ­das pagas: R$ {0:N2}'}"
                               TextColor="#15803D" FontSize="13"/>
                        <Label Text="{Binding Resumo.TotalPendente, StringFormat='SaÃ­das pendentes: R$ {0:N2}'}"
                               TextColor="#B45309" FontSize="13"/>
                        <Label Text="{Binding Resumo.TotalAtrasados, StringFormat='Atrasados: R$ {0:N2}'}"
                               TextColor="#DC2626" FontSize="13"/>
                        <Label Text="{Binding Resumo.TotalVencemHoje, StringFormat='Vencem hoje: R$ {0:N2}'}"
                               TextColor="#185FA5" FontSize="13"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- PrÃ³ximos vencimentos -->
                <Label Text="PrÃ³ximos vencimentos" FontSize="14" FontAttributes="Bold"/>

                <CollectionView ItemsSource="{Binding ProximosVencimentos}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Margin="0,0,0,6" Padding="12" CornerRadius="8"
                                   BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="False">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding Descricao}" FontSize="13" FontAttributes="Bold"/>
                                        <Label Text="{Binding Vencimento, StringFormat='{0:dd/MM/yyyy}'}"
                                               FontSize="11" TextColor="#6B7280"/>
                                        <Label Text="{Binding Conta}" FontSize="11" TextColor="#6B7280"/>
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                        <Label Text="{Binding Valor, StringFormat='R$ {0:N2}'}"
                                               FontSize="13" FontAttributes="Bold" HorizontalOptions="End"/>
                                        <Label Text="{Binding Status}" FontSize="11"
                                               HorizontalOptions="End" TextColor="#B45309"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>