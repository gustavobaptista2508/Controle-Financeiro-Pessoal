@inject NavigationManager Nav

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            var relativePath = Nav.ToBaseRelativePath(Nav.Uri);
            var returnUrl = string.IsNullOrWhiteSpace(relativePath) ? "/dashboard" : $"/{relativePath}";
            Nav.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: false);
        }
    }
}
