@inject NavigationManager Nav

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Evita forceLoad para não reiniciar o circuito Blazor Server,
            // preservando o estado de autenticação em WebAuthSessionService.
            Nav.NavigateTo("/auth");
        }
    }
}
