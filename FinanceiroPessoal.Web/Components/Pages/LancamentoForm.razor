@page "/lancamentos/novo"
@page "/lancamentos/editar/{Id:int}"
@using ModelLancamento = global::FinanceiroPessoal.Core.Models.Lancamento
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject LancamentoService LancamentoService
@inject NavigationManager Navigation
@inject CadastroAuxiliarService CadastroAuxiliarService

<PageTitle>@(Id.HasValue ? "Editar Lançamento" : "Cadastro de Lançamento")</PageTitle>

<h3>@(Id.HasValue ? "Editar Lançamento" : "Cadastro de Lançamento")</h3>

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-outline-primary" href="/lancamentos">Voltar para lançamentos</a>
    <a class="btn btn-outline-secondary" href="/">Voltar para página principal</a>
</div>

<EditForm Model="lancamento" OnValidSubmit="SalvarLancamento">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Descrição</label>
            <InputText class="form-control" @bind-Value="lancamento.Descricao" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Valor</label>
            <InputNumber class="form-control" @bind-Value="lancamento.Valor" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Tipo</label>
            <InputSelect class="form-select" @bind-Value="lancamento.Tipo">
                <option value="@TipoLancamento.Entrada">Entrada</option>
                <option value="@TipoLancamento.Saida">Saída</option>
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label">Vencimento</label>
            <InputDate class="form-control" @bind-Value="lancamento.DataVencimento" />
        </div>


        <div class="col-md-4">
            <label class="form-label">Categoria</label>
            <InputSelect class="form-select" @bind-Value="lancamento.CategoriaId">
                <option value="">Selecione...</option>
                @foreach (var categoria in categorias)
                {
                    <option value="@categoria.Id">@categoria.Nome</option>
                }
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label">Conta</label>
            <InputSelect class="form-select" @bind-Value="lancamento.ContaId">
                <option value="">Selecione...</option>
                @foreach (var conta in contas)
                {
                    <option value="@conta.Id">@conta.Nome</option>
                }
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label">Pessoa</label>
            <InputSelect class="form-select" @bind-Value="lancamento.PessoaId">
                <option value="">Selecione...</option>
                @foreach (var pessoa in pessoas)
                {
                    <option value="@pessoa.Id">@pessoa.Nome</option>
                }
            </InputSelect>
        </div>

        <div class="col-md-4">
            <label class="form-label">Status</label>
            <InputSelect class="form-select" @bind-Value="lancamento.Status">
                <option>Pendente</option>
                <option>Pago</option>
                <option>Atrasado</option>
            </InputSelect>
        </div>

        <div class="col-md-2">
            <label class="form-label">Parcelas</label>
            <InputNumber class="form-control" @bind-Value="quantidadeParcelas" min="1" disabled="@Id.HasValue" />
        </div>

        <div class="col-md-2">
            <label class="form-label">Competência</label>
            <InputText class="form-control" @bind-Value="lancamento.Competencia" placeholder="Ex: 05/2026" />
        </div>

        <div class="col-12">
            <label class="form-label">Observações</label>
            <InputTextArea class="form-control" @bind-Value="lancamento.Observacoes" rows="3" />
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <button type="submit" class="btn btn-success">Salvar</button>
        <a class="btn btn-outline-secondary" href="/lancamentos">Cancelar</a>
    </div>
</EditForm>

@if (!string.IsNullOrWhiteSpace(mensagem))
{
    <div class="alert alert-info mt-3">@mensagem</div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private ModelLancamento lancamento = new();
    private int quantidadeParcelas = 1;
    private string? mensagem;
    private List<Categoria> categorias = new();
    private List<Conta> contas = new();
    private List<Pessoa> pessoas = new();

    protected override async Task OnInitializedAsync()
    {
        categorias = await CadastroAuxiliarService.ObterCategorias();
        contas = await CadastroAuxiliarService.ObterContas();
        pessoas = await CadastroAuxiliarService.ObterPessoas();

        if (Id.HasValue)
        {
            var existente = await LancamentoService.ObterPorId(Id.Value);
            if (existente is not null)
            {
                lancamento = existente;
            }
        }
    }

    private async Task SalvarLancamento()
    {
        if (Id.HasValue)
        {
            await LancamentoService.Atualizar(lancamento);
            mensagem = "Lançamento atualizado com sucesso.";
        }
        else
        {
            var parcelas = Math.Max(1, quantidadeParcelas);
            var competenciaBase = ObterCompetenciaBase();
            var vencimentoBase = lancamento.DataVencimento?.Date ?? DateTime.Today;

            for (var parcela = 1; parcela <= parcelas; parcela++)
            {
                var novoLancamento = new ModelLancamento
                {
                    Descricao = parcelas > 1
                        ? $"{lancamento.Descricao} - Parcela {parcela} de {parcelas}"
                        : lancamento.Descricao,
                    Valor = lancamento.Valor,
                    DataVencimento = vencimentoBase.AddMonths(parcela - 1),
                    DataPagamento = parcela == 1 && lancamento.Status == "Pago" ? DateTime.Now : null,
                    Status = parcela == 1 ? lancamento.Status : "Pendente",
                    Observacoes = lancamento.Observacoes,
                    Competencia = competenciaBase.AddMonths(parcela - 1).ToString("MM/yyyy"),
                    Tipo = lancamento.Tipo,
                    CategoriaId = lancamento.CategoriaId,
                    ContaId = lancamento.ContaId,
                    PessoaId = lancamento.PessoaId
                };

                await LancamentoService.Adicionar(novoLancamento);
            }

            mensagem = "Lançamento cadastrado com sucesso.";
        }

        Navigation.NavigateTo("/lancamentos");
    }
    private DateTime ObterCompetenciaBase()
    {
        var competenciaTexto = (lancamento.Competencia ?? string.Empty).Trim();

        if (DateTime.TryParseExact($"01/{competenciaTexto}", "dd/MM/yyyy", null, System.Globalization.DateTimeStyles.None, out var competencia))
        {
            return competencia;
        }

        return lancamento.DataVencimento?.Date ?? DateTime.Today;
    }

}
