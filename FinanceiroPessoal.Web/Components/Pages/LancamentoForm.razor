@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@page "/lancamentos/novo"
@page "/lancamentos/editar/{Id:int}"
@using ModelLancamento = global::FinanceiroPessoal.Core.Models.Lancamento
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject LancamentoService LancamentoService
@inject NavigationManager Navigation
@inject CadastroAuxiliarService CadastroAuxiliarService

<PageTitle>@(Id.HasValue ? "Editar Lançamento" : "Cadastro de Lançamento")</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudStack Spacing="1" Class="mb-3">
        <MudText Typo="Typo.h4">@(Id.HasValue ? "Editar Lançamento" : "Novo Lançamento")</MudText>
        <MudText Typo="Typo.body2" Class="text-muted">Home > Lançamentos > @(Id.HasValue ? "Editar" : "Novo")</MudText>
    </MudStack>

    <MudPaper Class="pa-6 form-premium" Elevation="1">
        <EditForm FormName="lancamento-form" Model="lancamento" OnValidSubmit="SalvarLancamento">
            <DataAnnotationsValidator />
            <MudGrid Spacing="3">
                <MudItem xs="12" md="6"><MudTextField Label="Descrição" Variant="Variant.Outlined" @bind-Value="lancamento.Descricao" FullWidth="true" /></MudItem>
                <MudItem xs="12" md="3"><MudNumericField Label="Valor" Variant="Variant.Outlined" @bind-Value="lancamento.Valor" FullWidth="true" /></MudItem>
                <MudItem xs="12" md="3">
                    <MudSelect T="TipoLancamento" Label="Tipo" Variant="Variant.Outlined" @bind-Value="lancamento.Tipo">
                        <MudSelectItem Value="@TipoLancamento.Entrada">Entrada</MudSelectItem>
                        <MudSelectItem Value="@TipoLancamento.Saida">Saída</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4"><MudDatePicker Label="Vencimento" Variant="Variant.Outlined" @bind-Date="lancamento.DataVencimento" /></MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Categoria" Variant="Variant.Outlined" @bind-Value="lancamento.CategoriaId">
                        @foreach (var categoria in categorias) { <MudSelectItem Value="@((int?)categoria.Id)">@categoria.Nome</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Conta" Variant="Variant.Outlined" @bind-Value="lancamento.ContaId">
                        @foreach (var conta in contas) { <MudSelectItem Value="@((int?)conta.Id)">@conta.Nome</MudSelectItem> }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudSelect T="int?" Label="Pessoa" Variant="Variant.Outlined" @bind-Value="lancamento.PessoaId">
                        @foreach (var pessoa in pessoas) { <MudSelectItem Value="@((int?)pessoa.Id)">@pessoa.Nome</MudSelectItem> }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="string" Label="Status" Variant="Variant.Outlined" @bind-Value="lancamento.Status">
                        <MudSelectItem Value="@("Pendente")">Pendente</MudSelectItem><MudSelectItem Value="@("Pago")">Pago</MudSelectItem><MudSelectItem Value="@("Atrasado")">Atrasado</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="2"><MudNumericField Label="Parcelas" Variant="Variant.Outlined" @bind-Value="quantidadeParcelas" Min="1" Disabled="@Id.HasValue" /></MudItem>
                <MudItem xs="12" md="2"><MudTextField Label="Competência" Variant="Variant.Outlined" @bind-Value="lancamento.Competencia" Placeholder="Ex: 05/2026" FullWidth="true" /></MudItem>
                <MudItem xs="12"><MudTextField Label="Observações" Variant="Variant.Outlined" @bind-Value="lancamento.Observacoes" Lines="3" FullWidth="true" /></MudItem>
            </MudGrid>

            <MudStack Row="true" Spacing="2" Class="mt-6" Wrap="Wrap.Wrap">
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="MudBlazor.Color.Primary">Salvar</MudButton>
                <MudButton Href="/lancamentos" Variant="Variant.Outlined" Color="MudBlazor.Color.Default">Cancelar</MudButton>
            </MudStack>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }
    [SupplyParameterFromForm] private ModelLancamento lancamento { get; set; } = new();
    private int quantidadeParcelas = 1; private string? mensagem; private List<Categoria> categorias = new(); private List<Conta> contas = new(); private List<Pessoa> pessoas = new();
    protected override async Task OnInitializedAsync(){ categorias = await CadastroAuxiliarService.ObterCategorias(); contas = await CadastroAuxiliarService.ObterContas(); pessoas = await CadastroAuxiliarService.ObterPessoas(); if (Id.HasValue){ var existente = await LancamentoService.ObterPorId(Id.Value); if (existente is not null){ lancamento = existente; } } }
    private async Task SalvarLancamento(){ if (Id.HasValue){ await LancamentoService.Atualizar(lancamento); mensagem = "Lançamento atualizado com sucesso."; } else { var parcelas = Math.Max(1, quantidadeParcelas); var competenciaBase = ObterCompetenciaBase(); var vencimentoBase = lancamento.DataVencimento?.Date ?? DateTime.Today; for (var parcela = 1; parcela <= parcelas; parcela++){ var novoLancamento = new ModelLancamento{ Descricao = parcelas > 1 ? $"{lancamento.Descricao} - Parcela {parcela} de {parcelas}" : lancamento.Descricao, Valor = lancamento.Valor, DataVencimento = vencimentoBase.AddMonths(parcela - 1), DataPagamento = parcela == 1 && lancamento.Status == "Pago" ? DateTime.Now : null, Status = parcela == 1 ? lancamento.Status : "Pendente", Observacoes = lancamento.Observacoes, Competencia = competenciaBase.AddMonths(parcela - 1).ToString("MM/yyyy"), Tipo = lancamento.Tipo, CategoriaId = lancamento.CategoriaId, ContaId = lancamento.ContaId, PessoaId = lancamento.PessoaId }; await LancamentoService.Adicionar(novoLancamento);} mensagem = "Lançamento cadastrado com sucesso."; } Navigation.NavigateTo("/lancamentos"); }
    private DateTime ObterCompetenciaBase(){ var competenciaTexto = (lancamento.Competencia ?? string.Empty).Trim(); var formatos = new[] { "dd/MM/yyyy", "dd/M/yyyy" }; if (DateTime.TryParseExact($"01/{competenciaTexto}", formatos, System.Globalization.CultureInfo.InvariantCulture, System.Globalization.DateTimeStyles.None, out var competencia)){ return competencia; } return lancamento.DataVencimento?.Date ?? DateTime.Today; }
}
