@page "/usuarios/cadastro"
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session

<PageTitle>Cadastro</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="auth-page">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h5">Criar conta</MudText>
        <MudTextField Label="Nome" Variant="Variant.Outlined" @bind-Value="nome" FullWidth="true" />
        <MudTextField Label="E-mail" Variant="Variant.Outlined" @bind-Value="email" FullWidth="true" Class="mt-2" />
        <MudTextField Label="Senha" Variant="Variant.Outlined" InputType="InputType.Password" @bind-Value="senha" FullWidth="true" Class="mt-2" />
        <MudButton Class="mt-4" Color="Color.Secondary" Variant="Variant.Filled" FullWidth="true" OnClick="Cadastrar">Cadastrar</MudButton>
        @if (!string.IsNullOrWhiteSpace(msg)) { <MudAlert Severity="Severity.Success" Class="mt-3">@msg</MudAlert> }
    </MudPaper>
</MudContainer>

@code { string nome=""; string email=""; string senha=""; string? msg; void Cadastrar()=> msg=Session.RegisterUser(nome,email,senha); }
