@page "/usuarios/cadastro"
@using Microsoft.AspNetCore.Components.Forms
@using FinanceiroPessoal.Web.Models
@inject FinanceiroPessoal.Web.Services.UsuarioCadastroService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cadastro</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="auth-shell">
    <MudPaper Elevation="2" Class="auth-card pa-8">
        <MudText Typo="Typo.h4" Class="mb-1">Criar conta</MudText>
        <MudText Typo="Typo.body2" Class="mb-6 auth-subtitle">Comece agora seu controle financeiro premium.</MudText>

        <EditForm EditContext="@editContext"
                  OnValidSubmit="@HandleCadastro"
                  FormName="cadastroUsuarioForm">
            <DataAnnotationsValidator />

            <MudTextField T="string" Label="Nome" @bind-Value="cadastroModel.Nome" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" />
            <ValidationMessage For="@(() => cadastroModel.Nome)" />

            <MudTextField T="string" Label="E-mail" @bind-Value="cadastroModel.Email" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Class="mt-2" />
            <ValidationMessage For="@(() => cadastroModel.Email)" />

            <MudTextField T="string" Label="Senha" @bind-Value="cadastroModel.Senha" InputType="InputType.Password" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Class="mt-2" />
            <ValidationMessage For="@(() => cadastroModel.Senha)" />

            <MudTextField T="string" Label="Confirmar senha" @bind-Value="cadastroModel.ConfirmarSenha" InputType="InputType.Password" Variant="Variant.Outlined" FullWidth="true" Margin="Margin.Dense" Class="mt-2" />
            <ValidationMessage For="@(() => cadastroModel.ConfirmarSenha)" />

            <MudButton ButtonType="ButtonType.Submit"
                       Color="Color.Success"
                       Variant="Variant.Filled"
                       FullWidth="true"
                       Class="mt-5 auth-main-button">
                CADASTRAR
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private CadastroUsuarioModel cadastroModel = new();
    private EditContext editContext = default!;

    protected override void OnInitialized()
    {
        editContext = new EditContext(cadastroModel);
    }

    private async Task HandleCadastro()
    {
        if (cadastroModel.Senha != cadastroModel.ConfirmarSenha)
        {
            Snackbar.Add("As senhas não conferem.", Severity.Error);
            return;
        }

        var result = await AuthService.CadastrarAsync(cadastroModel);

        if (result.Success)
        {
            Snackbar.Add("Usuário cadastrado com sucesso.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result.Message, Severity.Error);
        }
    }

}
