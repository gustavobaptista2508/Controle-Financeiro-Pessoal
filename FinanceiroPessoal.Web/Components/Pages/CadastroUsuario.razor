@page "/usuarios/cadastro"
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session

<PageTitle>Cadastro de usuário</PageTitle>
<div class="container mt-4" style="max-width:520px;">
    <h3>Cadastrar usuário</h3>
    <div class="mb-2"><label>Nome</label><input class="form-control" @bind="nome" /></div>
    <div class="mb-2"><label>E-mail</label><input class="form-control" @bind="email" /></div>
    <div class="mb-3"><label>Senha</label><input class="form-control" type="password" @bind="senha" /></div>
    <button class="btn btn-success" @onclick="Cadastrar">Cadastrar</button>
    @if (!string.IsNullOrWhiteSpace(msg)) { <div class="alert alert-info mt-3">@msg</div> }
</div>

@code {
    private string nome = string.Empty;
    private string email = string.Empty;
    private string senha = string.Empty;
    private string? msg;

    private void Cadastrar()
    {
        var r = Session.RegisterUser(nome, email, senha);
        msg = r;
    }
}
