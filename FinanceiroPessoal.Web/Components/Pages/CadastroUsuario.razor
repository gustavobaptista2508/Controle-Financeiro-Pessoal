@page "/usuarios/cadastro"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using FinanceiroPessoal.Web.Models
@inject FinanceiroPessoal.Web.Services.UsuarioCadastroService AuthService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cadastro</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="auth-shell">
    <MudPaper Elevation="2" Class="auth-card pa-8">
        <MudText Typo="Typo.h4" Class="mb-1">Criar conta</MudText>
        <MudText Typo="Typo.body2" Class="mb-6 auth-subtitle">Comece agora seu controle financeiro premium.</MudText>

        <EditForm Model="@cadastroModel" OnValidSubmit="@HandleCadastro" FormName="cadastroUsuarioForm">
            <DataAnnotationsValidator />

            <InputText class="form-control" @bind-Value="cadastroModel.Nome" placeholder="Nome" />
            <ValidationMessage For="@(() => cadastroModel.Nome)" />

            <InputText class="form-control mt-2" @bind-Value="cadastroModel.Email" placeholder="E-mail" />
            <ValidationMessage For="@(() => cadastroModel.Email)" />

            <InputText class="form-control mt-2" type="password" @bind-Value="cadastroModel.Senha" placeholder="Senha" />
            <ValidationMessage For="@(() => cadastroModel.Senha)" />

            <InputText class="form-control mt-2" type="password" @bind-Value="cadastroModel.ConfirmarSenha" placeholder="Confirmar senha" />
            <ValidationMessage For="@(() => cadastroModel.ConfirmarSenha)" />

            <MudButton ButtonType="ButtonType.Submit"
                       Color="Color.Success"
                       Variant="Variant.Filled"
                       FullWidth="true"
                       Disabled="@isSaving"
                       Class="mt-5 auth-main-button">
                @(isSaving ? "CADASTRANDO..." : "CADASTRAR")
            </MudButton>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    private readonly CadastroUsuarioModel cadastroModel = new();
    private bool isSaving;

    private async Task HandleCadastro()
    {
        if (cadastroModel.Senha != cadastroModel.ConfirmarSenha)
        {
            Snackbar.Add("As senhas não conferem.", Severity.Error);
            return;
        }

        try
        {
            isSaving = true;

            Console.WriteLine($"CADASTRO DEBUG - Nome: {cadastroModel.Nome}");
            Console.WriteLine($"CADASTRO DEBUG - Email: {cadastroModel.Email}");
            Console.WriteLine($"CADASTRO DEBUG - Senha preenchida: {!string.IsNullOrWhiteSpace(cadastroModel.Senha)}");

            var result = await AuthService.CadastrarAsync(cadastroModel);

            if (result.Success)
            {
                Snackbar.Add("Cadastro realizado com sucesso.", Severity.Success);
                Navigation.NavigateTo("/login");
                return;
            }

            Snackbar.Add(result.Message ?? "Não foi possível realizar o cadastro.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }
}
