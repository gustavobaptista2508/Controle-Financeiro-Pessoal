@page "/usuarios/cadastro"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms
@using FinanceiroPessoal.Web.Models
@using FinanceiroPessoal.Core.Data
@inject FinanceiroPessoal.Web.Services.UsuarioCadastroService AuthService
@inject FinanceiroDbContext Db
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Cadastro</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="auth-shell">
    <MudPaper Elevation="2" Class="auth-card pa-8">
        <MudText Typo="Typo.h4" Class="mb-1">Criar conta</MudText>
        <MudText Typo="Typo.body2" Class="mb-6 auth-subtitle">Comece agora seu controle financeiro premium.</MudText>

        @if (planoSelecionado is not null)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                <strong>@planoSelecionado.Nome</strong> • @($"R$ {planoSelecionado.Preco:N2} / {planoSelecionado.Intervalo}")<br />
                14 dias grátis. Você só assina se quiser continuar.
            </MudAlert>
        }

        <EditForm Model="@cadastroModel" OnValidSubmit="@HandleCadastro" FormName="cadastroForm">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <InputText class="form-control" @bind-Value="cadastroModel.Nome" placeholder="Nome" />
            <InputText class="form-control mt-2" @bind-Value="cadastroModel.Email" placeholder="E-mail" />
            <InputText class="form-control mt-2" type="password" @bind-Value="cadastroModel.Senha" placeholder="Senha" />
            <InputText class="form-control mt-2" type="password" @bind-Value="cadastroModel.ConfirmarSenha" placeholder="Confirmar senha" />

            <button type="submit" class="btn btn-success mt-5 auth-main-button" disabled="@isSaving">
                @(isSaving ? "CARREGANDO..." : "Começar 14 dias grátis")
            </button>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name="planoId")] public int? PlanoId { get; set; }

    private readonly CadastroUsuarioModel cadastroModel = new();
    private bool isSaving;
    private FinanceiroPessoal.Core.Models.Plano? planoSelecionado;

    protected override async Task OnInitializedAsync()
    {
        if (!PlanoId.HasValue)
        {
            Navigation.NavigateTo("/planos", true);
            return;
        }

        planoSelecionado = await Db.Planos.FirstOrDefaultAsync(p => p.Id == PlanoId.Value && p.Ativo);
        if (planoSelecionado is null)
        {
            Navigation.NavigateTo("/planos", true);
        }
    }

    private async Task HandleCadastro()
    {
        if (isSaving)
            return;

        if (cadastroModel.Senha != cadastroModel.ConfirmarSenha)
        {
            Snackbar.Add("As senhas não conferem.", Severity.Error);
            return;
        }

        try
        {
            isSaving = true;
            Console.WriteLine("CADASTRO: iniciou");
            Console.WriteLine($"CADASTRO: planoId = {PlanoId}");
            Console.WriteLine("CADASTRO: criando usuário");

            var result = await AuthService.CadastrarAsync(cadastroModel, PlanoId);

            if (!result.Success)
            {
                Snackbar.Add(result.Message ?? "Não foi possível realizar o cadastro.", Severity.Error);
                return;
            }

            Console.WriteLine("CADASTRO: usuário criado");
            Console.WriteLine("CADASTRO: trial aplicado");
            Console.WriteLine("CADASTRO: redirecionando dashboard");

            Navigation.NavigateTo($"/login?email={Uri.EscapeDataString(cadastroModel.Email)}&cadastro=sucesso", forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine("ERRO CADASTRO: " + ex);
            Snackbar.Add("Não foi possível concluir o cadastro. Tente novamente.", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }
}
