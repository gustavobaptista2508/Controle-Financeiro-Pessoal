@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@page "/lancamentos"
@using FinanceiroPessoal.Core.Services
@inject LancamentoService LancamentoService
@inject ISnackbar Snackbar

<PageTitle>Lançamentos</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="MudBlazor.AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <div>
        <MudText Typo="Typo.h5">Consulta de Lançamentos</MudText>
        <MudText Typo="Typo.body2">Gestão inteligente de entradas e saídas.</MudText>
    </div>
    <MudButton Href="/lancamentos/novo" Variant="Variant.Filled" Color="MudBlazor.Color.Primary">Novo lançamento</MudButton>
</MudStack>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField Label="Descrição" @bind-Value="filtroDescricao" Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" Label="Status" @bind-Value="filtroStatus">
                <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                <MudSelectItem Value="@("Pendente")">Pendente</MudSelectItem>
                <MudSelectItem Value="@("Pago")">Pago</MudSelectItem>
                <MudSelectItem Value="@("Atrasado")">Atrasado</MudSelectItem>
                <MudSelectItem Value="@("Parcial")">Parcial</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="string" Label="Tipo" @bind-Value="filtroTipo">
                <MudSelectItem Value="@("Todos")">Todos</MudSelectItem>
                <MudSelectItem Value="@("Entrada")">Entrada</MudSelectItem>
                <MudSelectItem Value="@("Saída")">Saída</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudTable Items="LinhasFiltradas" Hover="true" Dense="true" Bordered="false" Striped="true">
    <HeaderContent>
        <MudTh>Status</MudTh><MudTh>Descrição</MudTh><MudTh>Valor</MudTh><MudTh>Vencimento</MudTh><MudTh>Categoria</MudTh><MudTh>Ações</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusIcone)">@context.StatusIcone</MudChip></MudTd>
        <MudTd>@context.Descricao</MudTd>
        <MudTd>@context.Valor.ToString("C")</MudTd>
        <MudTd>@context.Vencimento?.ToString("dd/MM/yyyy")</MudTd>
        <MudTd>@context.Categoria</MudTd>
        <MudTd>
            <MudButton Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Success" Variant="Variant.Text" Disabled="@(context.EhPago || _pagandoIds.Contains(context.Id))" OnClick="@(() => MarcarComoPago(context.Id))">Pagar</MudButton>
            <MudButton Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Error" Variant="Variant.Text" OnClick="@(() => Excluir(context.Id))">Excluir</MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<LancamentoLinhaDto> linhas = new();
    private readonly HashSet<int> _pagandoIds = new();
    private string filtroDescricao = string.Empty;
    private string filtroStatus = "Todos";
    private string filtroTipo = "Todos";
    private IEnumerable<LancamentoLinhaDto> LinhasFiltradas => linhas.Where(AtendeFiltros);
    protected override async Task OnInitializedAsync() => await Recarregar();

    private async Task Recarregar()
    {
        var lancamentos = await LancamentoService.ObterTodos();
        linhas = lancamentos.Select(x => new LancamentoLinhaDto
        {
            Id = x.Id,
            Tipo = x.Tipo == global::FinanceiroPessoal.Core.Models.TipoLancamento.Entrada ? "Entrada" : "Saída",
            Descricao = x.Descricao,
            Valor = x.Valor,
            Vencimento = x.DataVencimento,
            StatusIcone = x.Status,
            Categoria = x.Categoria?.Nome ?? string.Empty,
            EhPago = string.Equals(x.Status, "Pago", StringComparison.OrdinalIgnoreCase)
        }).OrderBy(x => x.Vencimento ?? DateTime.MaxValue).ToList();
    }

    private bool AtendeFiltros(LancamentoLinhaDto l) =>
        (string.IsNullOrWhiteSpace(filtroDescricao) || l.Descricao.Contains(filtroDescricao, StringComparison.OrdinalIgnoreCase)) &&
        (filtroStatus == "Todos" || string.Equals(l.StatusIcone, filtroStatus, StringComparison.OrdinalIgnoreCase)) &&
        (filtroTipo == "Todos" || string.Equals(l.Tipo, filtroTipo, StringComparison.OrdinalIgnoreCase));

    private async Task MarcarComoPago(int id)
    {
        if (_pagandoIds.Contains(id))
            return;

        try
        {
            _pagandoIds.Add(id);
            await LancamentoService.MarcarComoPago(id, DateTime.Today);
            await Recarregar();
            Snackbar.Add("Lançamento marcado como pago", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Não foi possível marcar o lançamento como pago. Tente novamente.", Severity.Error);
        }
        finally
        {
            _pagandoIds.Remove(id);
            StateHasChanged();
        }
    }
    private async Task Excluir(int id) { await LancamentoService.Excluir(id); await Recarregar(); }

    private static MudBlazor.Color GetStatusColor(string? status) => status?.Trim().ToLowerInvariant() switch
    {
        "pago" => MudBlazor.Color.Success,
        "atrasado" => MudBlazor.Color.Error,
        "parcial" => MudBlazor.Color.Info,
        _ => MudBlazor.Color.Warning
    };

    private sealed class LancamentoLinhaDto
    {
        public int Id { get; set; }
        public string Tipo { get; set; } = string.Empty;
        public string Descricao { get; set; } = string.Empty;
        public decimal Valor { get; set; }
        public DateTime? Vencimento { get; set; }
        public string StatusIcone { get; set; } = "Pendente";
        public string Categoria { get; set; } = string.Empty;
        public bool EhPago { get; set; }
    }
}
