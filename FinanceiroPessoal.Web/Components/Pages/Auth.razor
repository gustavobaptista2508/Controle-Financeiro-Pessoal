@page "/auth"
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session
@inject NavigationManager Navigation

<PageTitle>Autenticação</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="auth-page">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h5" GutterBottom="true">Autenticação</MudText>
        <MudText Class="mb-4">Fluxo WebAuthn foi removido. Use login por e-mail e senha.</MudText>
        <MudButton Href="/login" Variant="Variant.Filled" Color="MudBlazor.Color.Primary" FullWidth="true">Ir para login</MudButton>
    </MudPaper>
</MudContainer>

@code {
    protected override void OnInitialized()
    {
        if (Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/dashboard");
        }
    }
}
