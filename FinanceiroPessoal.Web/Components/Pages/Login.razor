@page "/login"
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session
@inject NavigationManager Nav

<PageTitle>Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="auth-page">
    <MudPaper Class="pa-6">
        <MudText Typo="Typo.h5" GutterBottom="true">Entrar no GranaOK</MudText>
        <MudTextField Label="E-mail" Variant="Variant.Outlined" @bind-Value="email" FullWidth="true" />
        <MudTextField Label="Senha" Variant="Variant.Outlined" InputType="InputType.Password" @bind-Value="senha" FullWidth="true" Class="mt-3" />
        @if (!string.IsNullOrWhiteSpace(erro)) { <MudAlert Severity="Severity.Error" Class="mt-3">@erro</MudAlert> }
        <MudButton Class="mt-4" Color="Color.Primary" Variant="Variant.Filled" FullWidth="true" OnClick="Entrar">Entrar</MudButton>
    </MudPaper>
</MudContainer>

@code { string email=""; string senha=""; string? erro; void Entrar(){ if(!Session.LoginWithPassword(email,senha)){erro="E-mail ou senha inválidos.";return;} Nav.NavigateTo("/"); } }
