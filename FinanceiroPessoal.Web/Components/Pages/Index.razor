@page "/dashboard"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudGrid>
    <MudItem xs="12">
        <MudPaper Class="hero">
            <MudText Typo="Typo.h4">Seu controle financeiro em tempo real</MudText>
            <MudText>Fluxo de caixa, despesas por categoria e visão mensal em um painel estilo fintech.</MudText>
        </MudPaper>
    </MudItem>

    @if (resumo is not null)
    {
        <MudItem xs="12" sm="6" md="3"><FinanceCard Title="Entradas" Value="@resumo.TotalEntradas.ToString("C")" Subtitle="@($"{resumo.QuantidadeEntradas} lançamentos")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><FinanceCard Title="Saídas" Value="@resumo.TotalSaidas.ToString("C")" Subtitle="@($"{resumo.QuantidadeSaidas} lançamentos")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><FinanceCard Title="Pendentes" Value="@resumo.TotalPendente.ToString("C")" Subtitle="@($"{resumo.QuantidadePendentes} aguardando")" /></MudItem>
        <MudItem xs="12" sm="6" md="3"><FinanceCard Title="Saldo do mês" Value="@resumo.SaldoMes.ToString("C")" Subtitle="Competência atual" /></MudItem>
    }

    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6">Despesas por categoria</MudText>
            <ApexChart TItem="GastoCategoriaDto" Options="gastosOptions" Height="320">
                <ApexPointSeries TItem="GastoCategoriaDto" Items="gastosPorCategoria" Name="Valor" SeriesType="SeriesType.Donut" XValue="@(e => e.Categoria)" YValue="@(e => e.Valor)" />
            </ApexChart>
        </MudPaper>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4 landing-callout">
            <MudText Typo="Typo.h5">Planeje. Poupe. Cresça.</MudText>
            <MudText Class="mb-3">Inspirado em Nubank, Cora, Mobills e Stripe, com experiência fluida no desktop e mobile.</MudText>
            <MudButton Href="/lancamentos" Variant="Variant.Filled" Color="Color.Primary">Ver lançamentos</MudButton>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private DashboardResumo? resumo;
    private List<GastoCategoriaDto> gastosPorCategoria = new();
    private readonly ApexChartOptions<GastoCategoriaDto> gastosOptions = new();

    protected override async Task OnInitializedAsync()
    {
        resumo = await DashboardService.ObterResumo(DateTime.Today);
        gastosPorCategoria = await DashboardService.ObterGastosPorCategoria(DateTime.Today);
    }
}
