@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using ApexCharts
@page "/dashboard"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="dashboard-shell">
    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudPaper Class="hero pa-6">
                <MudText Typo="Typo.h4">Seu controle financeiro em tempo real</MudText>
                <MudText>Fluxo de caixa, despesas por categoria e visão mensal em um painel SaaS moderno.</MudText>
            </MudPaper>
        </MudItem>

        @if (resumo is not null)
        {
            <MudItem xs="12" sm="6" md="4">
                <FinanceCard Title="Receitas" Value="@resumo.TotalEntradas.ToString(\"C\")" Subtitle="@($"{resumo.QuantidadeEntradas} lançamentos")" CardClass="card-receita" ValueClass="valor-receita" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <FinanceCard Title="Despesas" Value="@resumo.TotalSaidas.ToString(\"C\")" Subtitle="@($"{resumo.QuantidadeSaidas} lançamentos")" CardClass="card-despesa" ValueClass="valor-despesa" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <FinanceCard Title="Saldo" Value="@resumo.SaldoMes.ToString(\"C\")" Subtitle="Competência atual" CardClass="@SaldoCardClass" ValueClass="@SaldoValueClass" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <FinanceCard Title="Pendentes" Value="@resumo.TotalPendente.ToString(\"C\")" Subtitle="@($"{resumo.QuantidadePendentes} aguardando")" CardClass="card-pendente" ValueClass="valor-pendente" />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <FinanceCard Title="Pagos" Value="@resumo.TotalPago.ToString(\"C\")" Subtitle="@($"{resumo.QuantidadePagos} pagos")" CardClass="card-pago" ValueClass="valor-pago" />
            </MudItem>
        }

        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 chart-card">
                <MudText Typo="Typo.h6" Class="mb-2">Gastos por categoria</MudText>
                @if (gastosPorCategoria.Count == 0)
                {
                    <div class="empty-state">Nenhum gasto por categoria encontrado no período.</div>
                }
                else
                {
                    <ApexChart TItem="GastoCategoriaDto" Options="gastosOptions" Height="340">
                        <ApexPointSeries TItem="GastoCategoriaDto" Items="gastosPorCategoria" Name="Valor" SeriesType="SeriesType.Donut" XValue="@(e => e.Categoria)" YValue="@(e => e.Valor)" />
                    </ApexChart>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4 chart-card h-100">
                <MudText Typo="Typo.h6" Class="mb-2">Resumo financeiro</MudText>
                @if (resumo is null)
                {
                    <div class="empty-state">Sem dados para exibir.</div>
                }
                else
                {
                    <ApexChart TItem="decimal" Options="resumoOptions" Height="340">
                        <ApexPointSeries TItem="decimal" Items="receitasSerie" Name="Receitas" SeriesType="SeriesType.Line" XValue="@(v => referenciaResumo)" YValue="@(v => v)" />
                        <ApexPointSeries TItem="decimal" Items="despesasSerie" Name="Despesas" SeriesType="SeriesType.Line" XValue="@(v => referenciaResumo)" YValue="@(v => v)" />
                        <ApexPointSeries TItem="decimal" Items="saldoSerie" Name="Saldo" SeriesType="SeriesType.Line" XValue="@(v => referenciaResumo)" YValue="@(v => v)" />
                    </ApexChart>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private DashboardResumo? resumo;
    private List<GastoCategoriaDto> gastosPorCategoria = new();
    private List<decimal> receitasSerie = new();
    private List<decimal> despesasSerie = new();
    private List<decimal> saldoSerie = new();
    private string referenciaResumo = string.Empty;

    private readonly ApexChartOptions<GastoCategoriaDto> gastosOptions = new()
    {
        Legend = new Legend { Position = LegendPosition.Bottom },
        Colors = ["#22C55E", "#3B82F6", "#8B5CF6", "#EF4444", "#F59E0B", "#EC4899", "#06B6D4", "#64748B", "#F97316", "#94A3B8"]
    };

    private readonly ApexChartOptions<decimal> resumoOptions = new()
    {
        Colors = ["#22C55E", "#EF4444", "#3B82F6"],
        Stroke = new Stroke { Curve = StrokeCurve.Smooth, Width = [3, 3, 3] },
        Legend = new Legend { Position = LegendPosition.Bottom }
    };

    private string SaldoCardClass => resumo?.SaldoMes > 0 ? "card-saldo positivo" : resumo?.SaldoMes < 0 ? "card-saldo negativo" : "card-saldo neutro";
    private string SaldoValueClass => resumo?.SaldoMes > 0 ? "valor-saldo-positivo" : resumo?.SaldoMes < 0 ? "valor-saldo-negativo" : "valor-pago";

    protected override async Task OnInitializedAsync()
    {
        resumo = await DashboardService.ObterResumo(DateTime.Today);
        gastosPorCategoria = await DashboardService.ObterGastosPorCategoria(DateTime.Today);

        if (resumo is not null)
        {
            receitasSerie = [resumo.TotalEntradas];
            despesasSerie = [resumo.TotalSaidas];
            saldoSerie = [resumo.SaldoMes];
            referenciaResumo = DateTime.Today.ToString("MM/yyyy");
        }
    }
}
