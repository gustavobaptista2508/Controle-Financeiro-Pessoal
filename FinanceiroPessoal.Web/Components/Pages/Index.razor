@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@page "/dashboard"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Services
@using FinanceiroPessoal.Core.Models
@using System.Globalization
@inject DashboardService DashboardService

<PageTitle>Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="dashboard-shell">
    <MudGrid Spacing="3">
        <MudItem xs="12">
            <MudPaper Class="hero pa-6">
                <MudText Typo="Typo.h4">Seu controle financeiro em tempo real</MudText>
                <MudText>Fluxo de caixa, despesas por categoria e visão mensal em um painel SaaS moderno.</MudText>
            </MudPaper>
        </MudItem>

        @if (carregando)
        {
            <MudItem xs="12" Class="d-flex justify-center">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
            </MudItem>
        }
        else if (resumo is not null)
        {
            <MudItem xs="12" sm="6" md="3">
                <FinanceCard Title="Receitas" Value="@FormatarMoeda(resumo.TotalEntradas)" Subtitle="@($"{resumo.QuantidadeEntradas} lançamentos")" CardClass="card-receita" ValueClass="valor-receita" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <FinanceCard Title="Despesas" Value="@FormatarMoeda(resumo.TotalSaidas)" Subtitle="@($"{resumo.QuantidadeSaidas} lançamentos")" CardClass="card-despesa" ValueClass="valor-despesa" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <FinanceCard Title="Saldo" Value="@FormatarMoeda(resumo.SaldoMes)" Subtitle="Competência atual" CardClass="card-saldo" ValueClass="@SaldoValueClass" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <FinanceCard Title="Pendentes" Value="@FormatarMoeda(resumo.TotalPendente)" Subtitle="@($"{resumo.QuantidadePendentes} aguardando")" CardClass="card-pendente" ValueClass="valor-pendente" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 chart-card">
                    <MudText Typo="Typo.h6" Class="mb-2">Gastos por categoria</MudText>
                    @if (gastosCategoriaData.Length == 0)
                    {
                        <div class="empty-state">Nenhum gasto por categoria encontrado no período.</div>
                    }
                    else
                    {
                        <MudChart ChartType="ChartType.Donut"
                                  Labels="@gastosCategoriaLabels"
                                  InputData="@gastosCategoriaData"
                                  Width="100%"
                                  Height="320px" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4 chart-card h-100">
                    <MudText Typo="Typo.h6" Class="mb-2">Resumo financeiro</MudText>
                    <MudChart ChartType="ChartType.Line"
                              ChartSeries="@seriesResumo"
                              XAxisLabels="@resumoLabels"
                              Width="100%"
                              Height="320px" />
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private bool carregando = true;
    private DashboardResumo? resumo;

    private string[] gastosCategoriaLabels = Array.Empty<string>();
    private double[] gastosCategoriaData = Array.Empty<double>();

    private string[] resumoLabels = Array.Empty<string>();
    private List<ChartSeries> seriesResumo = new();

    private string SaldoValueClass => resumo?.SaldoMes >= 0 ? "valor-saldo-positivo" : "valor-saldo-negativo";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            carregando = true;

            var referencia = DateTime.Today;
            resumo = await DashboardService.ObterResumo(referencia);
            var gastosPorCategoria = await DashboardService.ObterGastosPorCategoria(referencia);

            gastosCategoriaLabels = gastosPorCategoria.Select(x => x.Categoria).ToArray();
            gastosCategoriaData = gastosPorCategoria.Select(x => Convert.ToDouble(x.Valor)).ToArray();

            if (resumo is not null)
            {
                resumoLabels = new[] { referencia.ToString("MM/yyyy", CultureInfo.GetCultureInfo("pt-BR")) };
                seriesResumo =
                [
                    new ChartSeries { Name = "Receitas", Data = new[] { Convert.ToDouble(resumo.TotalEntradas) } },
                    new ChartSeries { Name = "Despesas", Data = new[] { Convert.ToDouble(resumo.TotalSaidas) } },
                    new ChartSeries { Name = "Saldo", Data = new[] { Convert.ToDouble(resumo.SaldoMes) } }
                ];
            }
        }
        finally
        {
            carregando = false;
        }
    }

    private static string FormatarMoeda(decimal valor)
    {
        return valor.ToString("C", CultureInfo.GetCultureInfo("pt-BR"));
    }
}
