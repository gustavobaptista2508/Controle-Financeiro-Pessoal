@using Microsoft.AspNetCore.Components.Authorization
@page "/planos"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Data
@using Microsoft.EntityFrameworkCore
@inject FinanceiroDbContext Db
@inject NavigationManager Nav
@inject HttpClient Http
@inject AuthenticationStateProvider Auth

<h3>Planos</h3>
<p><strong>14 dias grátis</strong> para novos usuários.</p>

@if (isLoading)
{
    <p>Carregando planos...</p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <p class="text-danger">@errorMessage</p>
}
else
{
    @foreach (var p in planos)
    {
        <div class="mb-3">
            <strong>@p.Nome</strong><br />
            @p.Descricao<br />
            @($"R$ {p.Preco:N2} / {p.Intervalo}")<br />
            <button class="btn btn-success" @onclick="(()=>IrParaCadastro(p.Id))">Começar 14 dias grátis</button>
        </div>
    }
}

@code {
    private List<FinanceiroPessoal.Core.Models.Plano> planos = new();
    private bool isLoading;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        try
        {
            Console.WriteLine("PLANOS: carregando");
            planos = await Db.Planos.Where(x => x.Ativo).OrderBy(x => x.Preco).ToListAsync();
            Console.WriteLine($"PLANOS: quantidade = {planos.Count}");
            _ = await Auth.GetAuthenticationStateAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine("ERRO PLANOS: " + ex);
            errorMessage = "Não foi possível carregar os planos.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void IrParaCadastro(int id) => Nav.NavigateTo($"/usuarios/cadastro?planoId={id}");
}
