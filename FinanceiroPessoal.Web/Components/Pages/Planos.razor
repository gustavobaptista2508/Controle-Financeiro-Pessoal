@page "/planos"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Data
@using Microsoft.EntityFrameworkCore
@inject FinanceiroDbContext Db
@inject NavigationManager Nav

<h3>Planos</h3>
<p><strong>14 dias grátis</strong> para novos usuários.</p>

@if (carregando)
{
    <p>Carregando planos...</p>
}
else if (!string.IsNullOrWhiteSpace(erro))
{
    <p class="text-danger">@erro</p>
}
else
{
    @foreach (var p in planos)
    {
        <div class="mb-3">
            <strong>@p.Nome</strong><br />
            @p.Descricao<br />
            @($"R$ {p.Preco:N2} / {p.Intervalo}")<br />
            <button class="btn btn-success" @onclick="(()=>IrParaCadastro(p.Id))">Começar 14 dias grátis</button>
        </div>
    }
}

@code {
    private List<FinanceiroPessoal.Core.Models.Plano> planos = new();
    private bool carregando = true;
    private string? erro;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            carregando = true;
            erro = null;

            Console.WriteLine("PLANOS: iniciando carregamento");
            planos = await Db.Planos
                .AsNoTracking()
                .Where(x => x.Ativo)
                .OrderBy(x => x.Preco)
                .ToListAsync();
            Console.WriteLine($"PLANOS: quantidade encontrada {planos.Count}");
        }
        catch (Exception ex)
        {
            Console.WriteLine("ERRO AO CARREGAR PLANOS:");
            Console.WriteLine(ex.ToString());
            erro = "Erro ao carregar planos: " + ex.Message;
        }
        finally
        {
            carregando = false;
        }
    }

    private void IrParaCadastro(int id) => Nav.NavigateTo($"/usuarios/cadastro?planoId={id}");
}
