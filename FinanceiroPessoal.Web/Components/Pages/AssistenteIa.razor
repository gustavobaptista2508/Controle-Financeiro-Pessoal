@page "/ia"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject FinanceiroPessoal.Web.Services.IAssinaturaService AssinaturaService
@inject FinanceiroPessoal.Web.Services.IAssistenteFinanceiroIaService IaService
@inject NavigationManager Nav
@using FinanceiroPessoal.Core.Models

<PageTitle>Assistente Financeiro IA</PageTitle>
<MudPaper Class="pa-4">
    <MudText Typo="Typo.h5">Assistente Financeiro IA</MudText>
    <MudTextField @bind-Value="pergunta" Label="Pergunta" Lines="3" Variant="Variant.Outlined" FullWidth="true" Class="mt-3" />
    <MudStack Row="true" Spacing="2" Class="mt-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Perguntar">Perguntar</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="ResumoMes">Resumir meu mês</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Categorias">Analisar categorias</MudButton>
    </MudStack>
    <MudText Class="mt-3">@resposta</MudText>
</MudPaper>

<MudPaper Class="pa-4 mt-4">
    <MudText Typo="Typo.h6">Últimas conversas</MudText>
    @foreach (var c in historico)
    {
        <MudText Class="mt-2"><b>Q:</b> @c.Pergunta</MudText>
        <MudText><b>R:</b> @c.Resposta</MudText>
    }
</MudPaper>

@code {
    private string pergunta = "Faça um resumo do meu mês.";
    private string resposta = string.Empty;
    private IReadOnlyList<IaConversa> historico = Array.Empty<IaConversa>();

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(auth.User.Identity?.IsAuthenticated ?? false)) { Nav.NavigateTo("/login"); return; }
        var idClaim = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(idClaim) || !int.TryParse(idClaim, out var uid)) { Nav.NavigateTo("/login", true); return; }
        if (!await AssinaturaService.UsuarioTemAcessoAsync(uid)) { Nav.NavigateTo("/assinatura/bloqueada", true); return; }
        historico = await IaService.ListarUltimasConversasAsync(uid);
    }

    private async Task Perguntar() => await Chamar("/api/ia/perguntar", new { pergunta });
    private async Task ResumoMes() => await Chamar("/api/ia/resumo-mensal", new { mes = DateTime.Today.Month, ano = DateTime.Today.Year });
    private async Task Categorias() => await Chamar("/api/ia/analisar-categorias", new { mes = DateTime.Today.Month, ano = DateTime.Today.Year });

    private async Task Chamar(string url, object body)
    {
        var client = HttpClientFactory.CreateClient();
        var r = await client.PostAsJsonAsync(url, body);
        resposta = r.IsSuccessStatusCode ? (await r.Content.ReadFromJsonAsync<IaResposta>())?.Resposta ?? "Sem resposta." : "Não foi possível consultar a IA no momento.";
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var idClaim = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (string.IsNullOrWhiteSpace(idClaim) || !int.TryParse(idClaim, out var uid)) { Nav.NavigateTo("/login", true); return; }
        historico = await IaService.ListarUltimasConversasAsync(uid);
    }

    class IaResposta { public string Resposta { get; set; } = string.Empty; }
}
