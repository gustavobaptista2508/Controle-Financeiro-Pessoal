@page "/categorias"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject CadastroAuxiliarService CadastroAuxiliarService

<PageTitle>Categorias</PageTitle>

<div class="page-header">
    <div>
        <h2>Categorias</h2>
        <p>Organize seus lançamentos por tipo de receita ou despesa.</p>
    </div>
</div>

<div class="content-grid">
    <section class="card form-card">
        <EditForm Model="this" OnValidSubmit="SalvarCategoria">
            <div class="form-group">
                <label>Nova categoria</label>
                <input class="form-control" @bind="novoNomeCategoria" placeholder="Ex: Alimentação, Combustível, Salário" />
            </div>

            <button type="submit" class="btn-primary-granaok">Cadastrar categoria</button>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(mensagem))
        {
            <div class="alert alert-info mt-3 mb-0">@mensagem</div>
        }
    </section>

    <section class="card table-card">
        <div class="table-toolbar">
            <input class="form-control" @bind="filtro" placeholder="Buscar categoria..." />
        </div>

        @if (!CategoriasFiltradas.Any())
        {
            <div class="empty-state">Nenhuma categoria cadastrada.</div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var categoria in CategoriasFiltradas)
                    {
                        <tr>
                            <td>@categoria.Nome</td>
                            <td>
                                <div class="table-actions">
                                    <button type="button" class="btn-action" disabled>Editar</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

@code {
    private List<Categoria> categorias = new();
    private string novoNomeCategoria = string.Empty;
    private string filtro = string.Empty;
    private string? mensagem;

    private IEnumerable<Categoria> CategoriasFiltradas =>
        string.IsNullOrWhiteSpace(filtro)
            ? categorias
            : categorias.Where(x => x.Nome.Contains(filtro, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await CarregarCategorias();

    private async Task SalvarCategoria()
    {
        try
        {
            await CadastroAuxiliarService.AdicionarCategoriaAsync(novoNomeCategoria);
            novoNomeCategoria = string.Empty;
            mensagem = "Categoria cadastrada com sucesso.";
            await CarregarCategorias();
        }
        catch (Exception ex)
        {
            mensagem = ex.Message;
        }
    }

    private async Task CarregarCategorias() => categorias = await CadastroAuxiliarService.ObterCategorias();
}
