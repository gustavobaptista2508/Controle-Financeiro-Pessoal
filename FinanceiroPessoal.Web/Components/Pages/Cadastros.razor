@page "/categorias"
@rendermode InteractiveServer
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@inject CadastroAuxiliarService CadastroAuxiliarService

<PageTitle>Categorias</PageTitle>

<h3>Categorias</h3>

<div class="card mb-3">
    <div class="card-body">
        <EditForm Model="this" OnValidSubmit="SalvarCategoria">
            <div class="row g-2 align-items-end">
                <div class="col-12 col-md-8">
                    <label class="form-label">Nova categoria</label>
                    <input class="form-control" @bind="novoNomeCategoria" placeholder="Ex: Alimentação" />
                </div>
                <div class="col-12 col-md-4">
                    <button type="submit" class="btn btn-success w-100">Cadastrar categoria</button>
                </div>
            </div>
        </EditForm>

        @if (!string.IsNullOrWhiteSpace(mensagem))
        {
            <div class="alert alert-info mt-3 mb-0">@mensagem</div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">Categorias cadastradas</div>
    <ul class="list-group list-group-flush">
        @if (categorias.Count == 0)
        {
            <li class="list-group-item text-muted">Nenhuma categoria cadastrada.</li>
        }
        else
        {
            @foreach (var categoria in categorias)
            {
                <li class="list-group-item">@categoria.Nome</li>
            }
        }
    </ul>
</div>

@code {
    private List<Categoria> categorias = new();
    private string novoNomeCategoria = string.Empty;
    private string? mensagem;

    protected override async Task OnInitializedAsync()
    {
        await CarregarCategorias();
    }

    private async Task SalvarCategoria()
    {
        try
        {
            await CadastroAuxiliarService.AdicionarCategoriaAsync(novoNomeCategoria);
            novoNomeCategoria = string.Empty;
            mensagem = "Categoria cadastrada com sucesso.";
            await CarregarCategorias();
        }
        catch (Exception ex)
        {
            mensagem = ex.Message;
        }
    }

    private async Task CarregarCategorias()
    {
        categorias = await CadastroAuxiliarService.ObterCategorias();
    }
}
