@page "/cartoes/extrato/{ContaId:int}/{Ano:int}/{Mes:int}"
@using ModelLancamento = global::FinanceiroPessoal.Core.Models.Lancamento
@using FinanceiroPessoal.Core.Services
@inject LancamentoService LancamentoService
@inject ISnackbar Snackbar

<PageTitle>Extrato do Cartão</PageTitle>

<h3>Extrato do Cartão: @NomeCartao</h3>
<p class="text-muted">Referência: @Mes/@Ano</p>

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-outline-secondary" href="/lancamentos">Voltar para lançamentos</a>
    <a class="btn btn-outline-primary" href="/">Voltar para página principal</a>
</div>

@if (carregando)
{
    <p>Carregando extrato...</p>
}
else
{
    <div class="row g-3 mb-3">
        <div class="col-md-4"><div class="card"><div class="card-body"><strong>Total fatura:</strong> @total.ToString("C2")</div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><strong>Total pago:</strong> @pago.ToString("C2")</div></div></div>
        <div class="col-md-4"><div class="card"><div class="card-body"><strong>Total pendente:</strong> @pendente.ToString("C2")</div></div></div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Vencimento</th><th>Descrição</th><th>Categoria</th><th>Valor</th><th>Status</th><th>Ações</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in itens)
            {
                <tr class="@LinhaStatus(item.Status)">
                    <td>@(item.DataVencimento?.ToString("dd/MM/yyyy") ?? "")</td>
                    <td>@item.Descricao</td>
                    <td>@(item.Categoria?.Nome ?? "Sem categoria")</td>
                    <td>@item.Valor.ToString("N2")</td>
                    <td>@item.Status</td>
                    <td>
                        @if (item.Status != "Pago")
                        {
                            <button class="btn btn-sm btn-success" disabled="@_pagandoIds.Contains(item.Id)" @onclick="() => MarcarComoPago(item.Id)">Marcar como pago</button>
                            <button class="btn btn-sm btn-outline-primary ms-2" @onclick="() => AbrirExtrato(item)">Abrir extrato</button>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<MudDialog @bind-Visible="_dialogAberto" Options="_dialogOptions">
    <DialogContent>
        @if (_itemSelecionado is not null)
        {
            <MudStack Spacing="1">
                <MudText Typo="Typo.h6">@_itemSelecionado.Descricao</MudText>
                <MudText Typo="Typo.body2">@ObterParcelaTexto(_itemSelecionado)</MudText>
                <MudText Typo="Typo.body2">@_itemSelecionado.Valor.ToString("C")</MudText>
                <MudText Typo="Typo.body2">Vencimento: @_itemSelecionado.DataVencimento?.ToString("dd/MM/yyyy")</MudText>
                <MudText Typo="Typo.body2">Competência: @(_itemSelecionado.Competencia ?? "-")</MudText>
            </MudStack>
        }
    </DialogContent>
</MudDialog>

@code {
    [Parameter] public int ContaId { get; set; }
    [Parameter] public int Ano { get; set; }
    [Parameter] public int Mes { get; set; }
    [SupplyParameterFromQuery] public string? NomeCartao { get; set; }

    private bool carregando = true;
    private List<ModelLancamento> itens = new();
    private decimal total;
    private decimal pago;
    private decimal pendente;
    private readonly HashSet<int> _pagandoIds = new();
    private bool _dialogAberto;
    private ModelLancamento? _itemSelecionado;
    private readonly DialogOptions _dialogOptions = new() { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };

    protected override async Task OnInitializedAsync()
    {
        var inicio = new DateTime(Ano, Mes, 1);
        var fim = inicio.AddMonths(1).AddDays(-1);

        var competenciaMes = $"{Mes:00}/{Ano}";
        var todos = await LancamentoService.ObterTodos();
        itens = todos
            .Where(x => x.ContaId == ContaId && x.Tipo == FinanceiroPessoal.Core.Models.TipoLancamento.Saida)
            .Where(x =>
                string.Equals((x.Competencia ?? string.Empty).Trim(), competenciaMes, StringComparison.OrdinalIgnoreCase) ||
                (x.DataVencimento.HasValue && x.DataVencimento.Value.Month == Mes && x.DataVencimento.Value.Year == Ano))
            .OrderBy(x => x.DataVencimento)
            .ToList();

        total = itens.Sum(x => x.Valor);
        pago = itens.Where(x => x.Status == "Pago").Sum(x => x.Valor);
        pendente = itens.Where(x => x.Status != "Pago").Sum(x => x.Valor);

        carregando = false;
    }

    private async Task MarcarComoPago(int id)
    {
        if (_pagandoIds.Contains(id))
            return;

        try
        {
            _pagandoIds.Add(id);
            await LancamentoService.MarcarComoPago(id, DateTime.Today);
            await OnInitializedAsync();
            Snackbar.Add("Lançamento marcado como pago", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Falha ao atualizar o pagamento. Tente novamente.", Severity.Error);
        }
        finally
        {
            _pagandoIds.Remove(id);
            StateHasChanged();
        }
    }

    private void AbrirExtrato(ModelLancamento item)
    {
        _itemSelecionado = item;
        _dialogAberto = true;
    }

    private static string ObterParcelaTexto(ModelLancamento item)
    {
        const string marcador = "Parcela ";
        var descricao = item.Descricao ?? string.Empty;
        var idx = descricao.IndexOf(marcador, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) return "Parcela única";
        return descricao[(idx + marcador.Length)..].Trim();
    }

    private static string LinhaStatus(string? status) => status switch
    {
        "Pago" => "table-success",
        "Atrasado" => "table-danger",
        _ => "table-warning"
    };
}
