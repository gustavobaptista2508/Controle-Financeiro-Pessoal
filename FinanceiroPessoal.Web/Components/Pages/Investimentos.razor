@page "/investimentos"
@attribute [Authorize]
@using System.Security.Claims
@using FinanceiroPessoal.Core.Models
@using FinanceiroPessoal.Core.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject InvestimentoService InvestimentoService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<PageTitle>Carteira de Investimentos</PageTitle>

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
    <div>
        <MudText Typo="Typo.h5">Carteira de Investimentos <span class="badge-plus">PLUS</span></MudText>
        <MudText Typo="Typo.body2">Controle manual de ativos, rentabilidade e evolução patrimonial.</MudText>
        <MudText Typo="Typo.caption" Class="text-muted">Este módulo faz parte do plano Plus do GranaOK.</MudText>
    </div>
</MudStack>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 resumo-card resumo-azul"><MudText>Total investido</MudText><MudText Typo="Typo.h6">@TotalInvestido.ToString("C")</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 resumo-card resumo-roxo"><MudText>Valor atual da carteira</MudText><MudText Typo="Typo.h6">@ValorAtualCarteira.ToString("C")</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 resumo-card"><MudText>Rentabilidade R$</MudText><MudText Typo="Typo.h6" Class="@(RentabilidadeTotal >= 0 ? "valor-positivo" : "valor-negativo")">@RentabilidadeTotal.ToString("C")</MudText></MudPaper></MudItem>
    <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 resumo-card"><MudText>Rentabilidade %</MudText><MudText Typo="Typo.h6" Class="@(RentabilidadePercentualTotal >= 0 ? "valor-positivo" : "valor-negativo")">@RentabilidadePercentualTotal.ToString("N2")%</MudText></MudPaper></MudItem>
</MudGrid>

<MudPaper Class="pa-4 mb-4">
    <MudText Typo="Typo.h6">Cadastrar ativo</MudText>
    <MudGrid>
        <MudItem xs="12" md="4"><MudTextField Label="Nome do ativo" @bind-Value="form.Nome" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="2"><MudTextField Label="Ticker/Código" @bind-Value="form.Ticker" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="3"><MudSelect T="string" Label="Tipo do ativo" @bind-Value="form.Tipo" Variant="Variant.Outlined">@foreach (var tipo in tiposAtivo){<MudSelectItem Value="@tipo">@tipo</MudSelectItem>}</MudSelect></MudItem>
        <MudItem xs="12" md="3"><MudDatePicker Label="Data da compra" @bind-Date="dataCompra" Variant="Variant.Outlined" /></MudItem>
        <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="Valor investido" @bind-Value="form.ValorInvestido" Variant="Variant.Outlined" Min="0" /></MudItem>
        <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="Quantidade" @bind-Value="form.Quantidade" Variant="Variant.Outlined" Min="0.000001m" /></MudItem>
        <MudItem xs="12" md="4"><MudNumericField T="decimal" Label="Valor atual unitário" @bind-Value="form.ValorAtualUnitario" Variant="Variant.Outlined" Min="0" /></MudItem>
        <MudItem xs="12"><MudTextField Label="Observação" @bind-Value="form.Observacao" Variant="Variant.Outlined" Lines="3" /></MudItem>
        <MudItem xs="12"><MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SalvarAsync">@(form.Id == 0 ? "Cadastrar ativo" : "Salvar edição")</MudButton></MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Class="pa-4 mb-4"><MudTextField Label="Buscar por nome, ticker ou tipo" @bind-Value="filtro" Variant="Variant.Outlined" Immediate="true" /></MudPaper>

<MudTable Items="InvestimentosFiltrados" Hover="true" Dense="true" Striped="true">
    <HeaderContent><MudTh>Ativo</MudTh><MudTh>Tipo</MudTh><MudTh>Quantidade</MudTh><MudTh>Preço médio</MudTh><MudTh>Valor investido</MudTh><MudTh>Valor atual</MudTh><MudTh>Rentabilidade R$</MudTh><MudTh>Rentabilidade %</MudTh><MudTh>Ações</MudTh></HeaderContent>
    <RowTemplate>
        <MudTd>@context.Nome (@context.Ticker)</MudTd><MudTd>@context.Tipo</MudTd><MudTd>@context.Quantidade.ToString("N6")</MudTd><MudTd>@context.PrecoMedio.ToString("C")</MudTd><MudTd>@context.ValorInvestido.ToString("C")</MudTd><MudTd>@context.ValorAtualTotal.ToString("C")</MudTd>
        <MudTd Class="@(context.RentabilidadeValor >= 0 ? "valor-positivo" : "valor-negativo")">@context.RentabilidadeValor.ToString("C")</MudTd>
        <MudTd Class="@(context.RentabilidadePercentual >= 0 ? "valor-positivo" : "valor-negativo")">@context.RentabilidadePercentual.ToString("N2")%</MudTd>
        <MudTd><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Editar(context.Id))">Editar</MudButton><MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error" OnClick="@(() => ExcluirAsync(context.Id))">Excluir</MudButton></MudTd>
    </RowTemplate>
    <NoRecordsContent><MudText>Nenhum investimento cadastrado ainda.</MudText></NoRecordsContent>
</MudTable>

<style>
.badge-plus { background: linear-gradient(135deg, #7c3aed, #2563eb); color: #fff; border-radius: 999px; padding: 6px 12px; font-size: 12px; font-weight: 800; }
.valor-positivo { color: #16a34a; font-weight: 800; }
.valor-negativo { color: #dc2626; font-weight: 800; }
.resumo-card { border-radius: 12px; box-shadow: 0 2px 10px rgba(0,0,0,.08); }
.resumo-azul { border-left: 4px solid #2563eb; }
.resumo-roxo { border-left: 4px solid #7c3aed; }
</style>

@code {
    private readonly List<string> tiposAtivo = ["Ação", "FII", "Renda Fixa", "Cripto", "Fundo", "Tesouro Direto", "Outros"];
    private List<Investimento> investimentos = new();
    private Investimento form = new() { Tipo = "Outros" };
    private string filtro = string.Empty;
    private int usuarioId;
    private DateTime? dataCompra = DateTime.Today;

    private IEnumerable<Investimento> InvestimentosFiltrados => investimentos.Where(i => string.IsNullOrWhiteSpace(filtro) || i.Nome.Contains(filtro, StringComparison.OrdinalIgnoreCase) || (i.Ticker?.Contains(filtro, StringComparison.OrdinalIgnoreCase) ?? false) || i.Tipo.Contains(filtro, StringComparison.OrdinalIgnoreCase));
    private decimal TotalInvestido => investimentos.Sum(x => x.ValorInvestido);
    private decimal ValorAtualCarteira => investimentos.Sum(x => x.ValorAtualTotal);
    private decimal RentabilidadeTotal => ValorAtualCarteira - TotalInvestido;
    private decimal RentabilidadePercentualTotal => TotalInvestido > 0 ? (RentabilidadeTotal / TotalInvestido) * 100 : 0;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var claim = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(claim, out usuarioId))
        {
            Snackbar.Add("Usuário inválido.", Severity.Error);
            return;
        }

        // TODO: integrar bloqueio oficial do plano Plus quando regra estiver disponível.
        await CarregarAsync();
    }

    private async Task CarregarAsync() => investimentos = await InvestimentoService.ListarAsync(usuarioId);

    private async Task SalvarAsync()
    {
        try
        {
            form.UsuarioId = usuarioId;
            form.DataCompra = dataCompra ?? DateTime.Today;
            if (form.Id == 0) await InvestimentoService.CriarAsync(form); else await InvestimentoService.AtualizarAsync(form, usuarioId);
            await CarregarAsync();
            form = new Investimento { Tipo = "Outros" };
            dataCompra = DateTime.Today;
            Snackbar.Add("Investimento salvo com sucesso.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void Editar(int id)
    {
        var item = investimentos.First(x => x.Id == id);
        form = new Investimento { Id = item.Id, UsuarioId = item.UsuarioId, Nome = item.Nome, Ticker = item.Ticker, Tipo = item.Tipo, ValorInvestido = item.ValorInvestido, Quantidade = item.Quantidade, ValorAtualUnitario = item.ValorAtualUnitario, DataCompra = item.DataCompra, Observacao = item.Observacao };
        dataCompra = form.DataCompra;
    }

    private async Task ExcluirAsync(int id)
    {
        await InvestimentoService.ExcluirAsync(id, usuarioId);
        await CarregarAsync();
    }
}
