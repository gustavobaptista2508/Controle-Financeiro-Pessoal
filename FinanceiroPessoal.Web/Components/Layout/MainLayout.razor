@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudDrawer Elevation="1" Variant="DrawerVariant.Responsive" Open="@_drawerOpen" Class="app-sidebar">
        <div class="logo-area">
            <img src="granaok-logo.svg" alt="GranaOK" />
        </div>
        <MudNavMenu>
            <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard" Match="NavLinkMatch.All">Dashboard</MudNavLink>
            <MudNavLink Href="/lancamentos" Icon="@Icons.Material.Filled.ReceiptLong">Lançamentos</MudNavLink>
            <MudNavLink Href="/lancamentos/novo" Icon="@Icons.Material.Filled.AddCircle">Novo lançamento</MudNavLink>
            <MudNavLink Href="/login" Icon="@Icons.Material.Filled.Login">Login</MudNavLink>
            <MudNavLink Href="/usuarios/cadastro" Icon="@Icons.Material.Filled.PersonAdd">Cadastro</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudAppBar Elevation="0" Dense="true" Class="topbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" />
            <MudText Typo="Typo.h6">GranaOK</MudText>
            <MudSpacer />
            <MudText Typo="Typo.body2" Class="me-2 d-none d-md-flex">Visão financeira inteligente</MudText>
            <MudAvatar Color="Color.Primary">GO</MudAvatar>
        </MudAppBar>

        <MudContainer MaxWidth="MaxWidth.False" Class="content-area">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#00C853",
            Secondary = "#003B7A",
            Background = "#F4F8FC",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#003B7A"
        }
    };

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
