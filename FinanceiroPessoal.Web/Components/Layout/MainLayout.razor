@inherits LayoutComponentBase
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://docs.microsoft.com/aspnet/" target="_blank">Sobre</a>
        </div>

        <article class="content px-4">
            @if (CanRenderProtectedContent)
            {
                @Body
            }
        </article>
    </main>
</div>

@code {
    private bool CanRenderProtectedContent;

    protected override void OnParametersSet()
    {
        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Trim('/');
        var isAuthRoute = string.Equals(relativePath, "auth", StringComparison.OrdinalIgnoreCase);

        CanRenderProtectedContent = Session.IsAuthenticated || isAuthRoute;

        if (!CanRenderProtectedContent)
        {
            Nav.NavigateTo("/auth", true);
        }
    }
}
