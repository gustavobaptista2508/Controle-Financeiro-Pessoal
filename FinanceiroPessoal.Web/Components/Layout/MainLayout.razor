@inherits LayoutComponentBase
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://docs.microsoft.com/aspnet/" target="_blank">Sobre</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        var relativePath = Nav.ToBaseRelativePath(Nav.Uri).Trim('/');
        if (!Session.IsAuthenticated && !string.Equals(relativePath, "auth", StringComparison.OrdinalIgnoreCase))
        {
            Nav.NavigateTo("/auth", true);
        }
    }
}
