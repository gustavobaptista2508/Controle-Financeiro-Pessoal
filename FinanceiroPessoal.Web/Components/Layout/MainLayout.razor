@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor
@inject FinanceiroPessoal.Web.Services.WebAuthSessionService Session
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims

<div class="layout @(sidebarCollapsed ? "sidebar-collapsed" : string.Empty)">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="main">
        <header class="topbar">
            <button class="hamburger-btn" @onclick="ToggleSidebar" aria-label="Alternar menu lateral">
                <span class="hamburger-icon">☰</span>
            </button>

            <div class="topbar-actions">
                <AuthorizeView>
                    <Authorized>
                        <div class="user-pill">
                            <span class="user-avatar">@GetInitials(context.User)</span>
                            <span class="user-name">@GetDisplayName(context.User)</span>
                            <button class="logout-btn" @onclick="Logout">Sair</button>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="login-btn">Entrar</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="content">
            @Body
        </section>
    </main>
</div>

@code {
    private bool sidebarCollapsed;

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    private static string GetDisplayName(ClaimsPrincipal user) => user.Identity?.Name ?? "Usuário";

    private static string GetInitials(ClaimsPrincipal user)
    {
        var name = GetDisplayName(user);
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "GO";
        if (parts.Length == 1) return parts[0][..1].ToUpperInvariant();
        return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
    }

    private async Task Logout()
    {
        var context = HttpContextAccessor.HttpContext;
        if (context is not null)
            await Session.LogoutAsync(context);

        Navigation.NavigateTo("/login", true);
    }
}
