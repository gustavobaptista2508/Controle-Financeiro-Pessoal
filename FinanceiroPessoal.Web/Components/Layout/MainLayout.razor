@inherits LayoutComponentBase

<div class="container-fluid min-vh-100 py-2 py-md-3">
    <div class="row g-0 flex-nowrap rounded-4 overflow-hidden border">
        <aside class="col-12 col-md-3 col-xl-2 p-0 bg-primary bg-gradient text-white d-none d-md-flex flex-column">
            <NavMenu />
        </aside>

        <div class="col bg-light p-0 d-flex flex-column">
            <header class="navbar navbar-expand bg-white border-bottom px-3 py-2 shadow-sm">
                <button class="btn btn-link text-dark p-0 me-3" title="Menu">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="ms-auto d-flex align-items-center gap-3">
                    <i class="bi bi-search"></i>
                    <i class="bi bi-bell"></i>
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge rounded-pill text-bg-dark px-3 py-2">GU</span>
                        <div class="d-none d-sm-block lh-1">
                            <strong class="d-block">Gustavo</strong>
                            <small class="text-muted">Perfil</small>
                        </div>
                    </div>
                </div>
            </header>

            <main class="p-3 p-md-4">
                @Body
            </main>
        </div>
    </div>
</div>


<div class="mobile-nav d-md-none fixed-bottom bg-white border-top shadow-sm">
    <div class="nav nav-pills nav-justified py-1">
        <a class="nav-link" href="/"><i class="bi bi-house d-block"></i><small>Dashboard</small></a>
        <a class="nav-link" href="/lancamentos"><i class="bi bi-card-list d-block"></i><small>Lançamentos</small></a>
        <a class="nav-link" href="/lancamentos/novo"><i class="bi bi-plus-square d-block"></i><small>Novo</small></a>
    </div>
</div>
