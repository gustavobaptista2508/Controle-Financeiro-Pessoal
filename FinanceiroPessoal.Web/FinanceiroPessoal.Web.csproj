  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Blazor-ApexCharts" Version="6.1.0" />
    <PackageReference Include="MudBlazor" Version="7.15.0" />
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
